{
	"name": "soderlind/azure-ai-foundry",
	"description": "Azure AI Foundry Connector for WordPress",
	"type": "wordpress-plugin",
	"license": "GPL-2.0-or-later",
	"require": {
		"php": ">=8.3"
	},
	"require-dev": {
		"phpunit/phpunit": "^12.5",
		"brain/monkey": "^2.6",
		"mockery/mockery": "^1.6"
	},
	"autoload": {
		"psr-4": {
			"AzureAiFoundry\\": "src/"
		}
	},
	"autoload-dev": {
		"psr-4": {
			"AzureAiFoundry\\Tests\\": "tests/php/"
		}
	},
	"scripts": {
		"test": "phpunit",
		"test:coverage": "phpunit --coverage-text"
	},
	"config": {
		"optimize-autoloader": true,
		"sort-packages": true
	}
}